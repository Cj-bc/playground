<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <!-- Emacs のロックファイル (.#foo.cs) をコンパイル対象から除外 -->
    <Compile Remove="**/.#*.cs" />
  </ItemGroup>

</Project>
